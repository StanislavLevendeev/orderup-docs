@startuml ProcessPayment
title Process Payment Flow

actor "Waiter\nApp" as Cashier
participant "API\nGateway" as Gateway
participant "Payment\nService" as PS
participant "Order\nService" as OS
participant "ActiveMQ\nBroker" as Queue
participant "Order Status\nService" as OSS

Cashier -> Gateway: POST /orders/{orderId}/payments\n{method: "CREDIT_CARD"}
activate Gateway
Gateway -> PS: Forward request
activate PS

PS -> OS: GET /orders/{orderId}
activate OS
OS --> PS: Order{id, items, status}
deactivate OS

PS -> PS: Calculate Total\n(exclude CANCELLED items,\nsum: unitPrice * quantity)

PS -> PS: Validate order total > 0

PS -> PS: CREATE Payment Record\n(store in-memory)

PS -> Queue: PUBLISH PaymentSucceededEvent\n(async, non-blocking)
activate Queue

PS --> Gateway: HTTP 201 Created\nPayment{id, orderId, amount, status}
deactivate PS
Gateway --> Cashier: Response
deactivate Gateway

par Async Event Processing
  Queue -> OSS: Message on topic: payments
  activate OSS
  
  OSS -> OSS: UPDATE Order.status = PAID\n(record in OrderStatusHistory)
  
  OSS -> Queue: PUBLISH OrderStatusChangedEvent\n(async)
  
  Queue -> OS: Message on topic:\norder-status-changed
  activate OS
  OS -> OS: UPDATE Order.status = PAID
  OS --> Queue: Event consumed
  deactivate OS
  
  deactivate OSS
end

deactivate Queue
@enduml
